#!/usr/bin/env bash
#
# Copyright Datadatdat.

#
# Utility script used during the docker build process to download and extract ZFS userland, using the same shell
# methods as are used at runtime.
#

# shellcheck source=util.sh
source "$(dirname "$0")/util.sh"

set -xe

zfs_version="2.3.4"

# Detect architecture
arch=$(uname -m)
case "$arch" in
    x86_64)
        arch_suffix="amd64"
        ;;
    aarch64|arm64)
        arch_suffix="arm64"
        ;;
    *)
        log_error "Unsupported architecture: $arch"
        exit 1
        ;;
esac

# Use local file from git repository
local_file="/datadatdat/assets/zfs-$zfs_version-userland-$arch_suffix.tar.gz"
if [[ -f "$local_file" ]]; then
    echo "Using local ZFS userland file for $arch ($arch_suffix): $local_file"
    cp "$local_file" /var/tmp/userland.tar.gz
else
    log_error "Local ZFS userland file not found: $local_file"
    exit 1
fi

cd / && tar --skip-old-files -xvzf /var/tmp/userland.tar.gz
rm /var/tmp/userland.tar.gz

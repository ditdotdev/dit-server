#!/usr/bin/env bash
#
# Copyright Dit.
#

#
# Entry point for running a kubernetes operation. See KubernetesRunner for how this works. We expect the DATADATDAT_PATH
# environment variable to point to the base path for volumes and configuration, which is then passed to the runner.
#

exec java -DbasePath=$DATADATDAT_PATH -cp /ditdotdev/dit-server.jar dev.dit.context.kubernetes.KubernetesRunnerKt


#!/usr/bin/env bash
#
# Copyright Datadatdat.
#

#
# Main entry point for the datadatdat server. This server can be run in different contexts, such as managing local
# docker containers or kubernetes pods. The behavior is controlled via the DATADATDAT_CONTEXT environemnt variable.
# We currently support two contexts:
#
#   docker-zfs      Controls local containers on your laptops, backing storage via ZFS. The DATADATDAT_IDENTITY
#                   environment variable must be set, which must also match the name of the corresponding storage
#                   pool, and the container must be run via the 'launch' script to ensure that ZFS is properly
#                   configured.
#
#   kubernetes-csi  Controls remote containers running in a kubernetes cluster, backing storage via a CSI
#                   driver. The DATADATDAT_IDENTITY variable must be set to determine where to place the persistent
#                   database in /var/lib/$DATADATDAT_IDENTITY, which should be backed by a persistent volume. Unlike
#                   the docker-zfs context, the server doesn't need to be run via 'launch', and can operate
#                   in any docker environment even if kernel ZFS support isn't present. Additional context
#                   can be passed through the DATADATDAT_CONFIG variable, which is a list of name=value pairs,
#                   separated by commas.
#

set -x

#
# Return a timestamp to use in log messages and elsewhere.
#
function timestamp {
  date +"%F_%T"
}

function log_error {
  local ts=$(timestamp)
  local msg=$1
  echo "$ts $log_delimiter ERROR $msg"
  exit 1
}

#
# Mount the database filesystem for the datadatdat server.
#
function mount_database() {
  local db_dir=$1
  mount | grep ^$DATADATDAT_IDENTITY/db > /dev/null
  if [[ $? != 0 ]]; then
    echo "Mounting $DATADATDAT_IDENTITY/db at $db_dir"
    mkdir -p $db_dir
    mount -i -t zfs $DATADATDAT_IDENTITY/db $db_dir || log_error "failed to mount database directory"
  fi
}

#
# Fix database permissions and handle version incompatibilities
#
function fix_database_permissions() {
  local db_dir=$1
  
  # Ensure proper ownership of database directory
  echo "Fixing database directory ownership"
  chown -R postgres:postgres $db_dir
  
  # Check for PostgreSQL version incompatibility
  if [[ -f $db_dir/PG_VERSION ]]; then
    local db_version=$(cat $db_dir/PG_VERSION)
    local server_version="12"
    if [[ "$db_version" != "$server_version" ]]; then
      echo "WARNING: Database version $db_version incompatible with server version $server_version"
      echo "Clearing database directory for fresh initialization"
      rm -rf $db_dir/*
      chown postgres:postgres $db_dir
    fi
  fi
}

#
# Initialize the database
#
function start_database() {
  local db_dir=$1
  local create_db=false
  mkdir -p $db_dir
  if [[ ! -f $db_dir/postgresql.conf ]]; then
    echo "Initializing database at $db_dir"
    chown postgres $db_dir
    su - postgres -c "/usr/lib/postgresql/12/bin/pg_ctl -D $db_dir initdb" || exit 1
    create_db=true
  fi

  # Start postgres
  echo "Starting postgres"
  rm -f $db_dir/postmaster.pid
  su - postgres -c "/usr/lib/postgresql/12/bin/pg_ctl -D $db_dir -l /var/log/postgresql/logfile start"
  if [[ $? == 1 ]]; then
    cat /var/log/postgresql/logfile
    exit 1
  fi
  [[ $create_db == "true" ]] && su - postgres -c "/usr/lib/postgresql/12/bin/createdb datadatdat"
  echo "Postgres started"
}

#
# Check that our context is configured correctly
#
[[ -z $DATADATDAT_CONTEXT ]] && log_error "DATADATDAT_CONTEXT must be set"
[[ -z $DATADATDAT_IDENTITY ]] && log_error "DATADATDAT_IDENTITY must be set"

#
# Check or configure any context-specific configuration.
#
DB_DIR=/var/lib/$DATADATDAT_IDENTITY/mnt/_db
if [[ $DATADATDAT_CONTEXT = "docker-zfs" ]]; then
  mount_database $DB_DIR
  fix_database_permissions $DB_DIR
  start_database $DB_DIR

  # Forward docker volume requests to datadatdat-server
  /datadatdat/docker-volume-proxy /run/docker/plugins/$DATADATDAT_IDENTITY.sock > /var/log/docker-proxy.log 2>&1 &

  exec java -Ddatadatdat.context=$DATADATDAT_CONTEXT -Ddatadatdat.contextConfig=pool=$DATADATDAT_IDENTITY -jar /datadatdat/datadatdat-server.jar
elif [[ $DATADATDAT_CONTEXT = "kubernetes-csi" ]]; then
  start_database $DB_DIR

  exec java -Ddatadatdat.context=$DATADATDAT_CONTEXT -Ddatadatdat.contextConfig=$DATADATDAT_CONFIG -Djdk.tls.client.protocols=TLSv1.2 -jar /datadatdat/datadatdat-server.jar
else
  log_error "Unknown context $DATADATDAT_CONTEXT"
fi

#!/usr/bin/env bash
# Copyright Dit 2026
# SPDX-License-Identifier: BUSL-1.1
#

#
# Main entry point for the dit server. This server can be run in different contexts, such as managing local
# docker containers or kubernetes pods. The behavior is controlled via the DIT_CONTEXT environemnt variable.
# We currently support two contexts:
#
#   docker-zfs      Controls local containers on your laptops, backing storage via ZFS. The DIT_IDENTITY
#                   environment variable must be set, which must also match the name of the corresponding storage
#                   pool, and the container must be run via the 'launch' script to ensure that ZFS is properly
#                   configured.
#
#   kubernetes-csi  Controls remote containers running in a kubernetes cluster, backing storage via a CSI
#                   driver. The DIT_IDENTITY variable must be set to determine where to place the persistent
#                   database in /var/lib/$DIT_IDENTITY, which should be backed by a persistent volume. Unlike
#                   the docker-zfs context, the server doesn't need to be run via 'launch', and can operate
#                   in any docker environment even if kernel ZFS support isn't present. Additional context
#                   can be passed through the DIT_CONTEXT_CONFIG variable, which is a list of name=value
#                   pairs, separated by commas (e.g. storageClass=csi-hostpath-sc,snapshotClass=csi-hostpath-snapclass).
#

set -x

#
# Return a timestamp to use in log messages and elsewhere.
#
function timestamp {
  date +"%F_%T"
}

function log_error {
  local ts=$(timestamp)
  local msg=$1
  echo "$ts $log_delimiter ERROR $msg"
  exit 1
}

#
# Mount the database filesystem for the dit server.
#
function mount_database() {
  local db_dir=$1
  mount | grep ^$DIT_IDENTITY/db > /dev/null
  if [[ $? != 0 ]]; then
    echo "Mounting $DIT_IDENTITY/db at $db_dir"
    mkdir -p $db_dir
    mount -i -t zfs $DIT_IDENTITY/db $db_dir || log_error "failed to mount database directory"
  fi
}

#
# Detect the installed PostgreSQL version and set PG_BIN accordingly
#
PG_VERSION_INSTALLED=$(ls /usr/lib/postgresql/ | sort -n | tail -1)
PG_BIN="/usr/lib/postgresql/${PG_VERSION_INSTALLED}/bin"
echo "Detected PostgreSQL version: $PG_VERSION_INSTALLED (binaries: $PG_BIN)"

#
# Fix database permissions and handle version incompatibilities
#
function fix_database_permissions() {
  local db_dir=$1

  # Ensure proper ownership of database directory
  echo "Fixing database directory ownership"
  chown -R postgres:postgres $db_dir

  # Check for PostgreSQL version incompatibility
  if [[ -f $db_dir/PG_VERSION ]]; then
    local db_version=$(cat $db_dir/PG_VERSION)
    if [[ "$db_version" != "$PG_VERSION_INSTALLED" ]]; then
      echo "WARNING: Database version $db_version incompatible with server version $PG_VERSION_INSTALLED"
      echo "Clearing database directory for fresh initialization"
      rm -rf $db_dir/*
      chown postgres:postgres $db_dir
    fi
  fi
}

#
# Initialize the database
#
function start_database() {
  local db_dir=$1
  local create_db=false
  mkdir -p $db_dir
  if [[ ! -f $db_dir/postgresql.conf ]]; then
    echo "Initializing database at $db_dir"
    chown postgres $db_dir
    su - postgres -c "$PG_BIN/pg_ctl -D $db_dir initdb" || exit 1
    create_db=true
  fi

  # Start postgres
  echo "Starting postgres"
  rm -f $db_dir/postmaster.pid
  su - postgres -c "$PG_BIN/pg_ctl -D $db_dir -l /var/log/postgresql/logfile start"
  if [[ $? == 1 ]]; then
    cat /var/log/postgresql/logfile
    exit 1
  fi
  [[ $create_db == "true" ]] && su - postgres -c "$PG_BIN/createdb dit"
  echo "Postgres started"
}

#
# Check that our context is configured correctly
#
[[ -z $DIT_CONTEXT ]] && log_error "DIT_CONTEXT must be set"
[[ -z $DIT_IDENTITY ]] && log_error "DIT_IDENTITY must be set"

#
# Check or configure any context-specific configuration.
#
DB_DIR=/var/lib/$DIT_IDENTITY/mnt/_db
if [[ $DIT_CONTEXT = "docker-zfs" ]]; then
  mount_database $DB_DIR
  fix_database_permissions $DB_DIR
  start_database $DB_DIR

  # Forward docker volume requests to dit-server
  /dit/docker-volume-proxy /run/docker/plugins/$DIT_IDENTITY.sock > /var/log/docker-proxy.log 2>&1 &

  # -Ddit.debug=true enables stack traces in ApiError.details
  # responses. Safe here — this image serves the local CLI over
  # loopback; the user is the operator and the stack helps diagnose
  # ZFS / Docker plumbing issues. NOT set in dit-remote-server
  # which fronts the API to remote clients.
  exec java -Ddit.context=$DIT_CONTEXT -Ddit.contextConfig=pool=$DIT_IDENTITY -Ddit.debug=true -jar /dit/dit-server.jar
elif [[ $DIT_CONTEXT = "kubernetes-csi" ]]; then
  start_database $DB_DIR

  exec java -Ddit.context=$DIT_CONTEXT -Ddit.contextConfig=$DIT_CONTEXT_CONFIG -Ddit.debug=true -Djdk.tls.client.protocols=TLSv1.2 -jar /dit/dit-server.jar
else
  log_error "Unknown context $DIT_CONTEXT"
fi
